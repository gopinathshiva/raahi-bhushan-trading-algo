# .env.example — Copy to .env and fill in your values.
# .env is gitignored. This file (no secrets) is safe to commit.

# ─── Database Backend ──────────────────────────────────────────────────────────
# 'sqlite'   — local SQLite file (sensibull.db). Default for local dev.
# 'supabase' — Supabase PostgreSQL. Required for Render deployment.
DB_BACKEND=sqlite

# Supabase transaction pooler URL (port 6543).
# Found in: Supabase Dashboard → Settings → Database → Connection pooling → Transaction mode.
# Only required when DB_BACKEND=supabase.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require

# ─── App Security ──────────────────────────────────────────────────────────────
# Flask session secret. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Admin registration gate code (users must enter this code to register).
REGISTRATION_CODE=

# Bearer token for /api/trigger-scrape endpoint. Generate same as SECRET_KEY.
SCRAPE_TOKEN=

# ─── AI API Keys ───────────────────────────────────────────────────────────────
# Anthropic API key — from console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini API key — from aistudio.google.com
GEMINI_API_KEY=

# ─── Optional ──────────────────────────────────────────────────────────────────
# Market holidays API (if used for is_market_open() checks)
MARKET_HOLIDAYS_API_URL=
MARKET_HOLIDAYS_API_KEY=
